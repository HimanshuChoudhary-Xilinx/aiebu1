{
    print("\ntracing started ...\n")
    tss = timestamp32()
    print(f"begin ts: {tss:d}")

@blockopen
def factorial(n):
    """Return the factorial of n."""
    if n < 0:
        return None
    result = 1
    for i in range(2, n + 1):
        result *= i
    return result
@blockclose

